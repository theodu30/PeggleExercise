<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:Label text="Score: 0" name="Score" style="position: absolute; top: 100px; left: 150px; font-size: 50px; -unity-font-style: bold;"/>
    <ui:Label text="Ball: 0" name="Ball" style="position: absolute; top: 100px; left: auto; font-size: 50px; -unity-font-style: bold; right: 150px; -unity-text-align: upper-right;"/>
    <ui:VisualElement name="EndOfGame" style="position: absolute; align-self: center; align-items: center; top: 200px; visibility: hidden;">
        <ui:Label text="END OF GAME TEXT" name="" style="-unity-text-align: upper-center; font-size: 50px; position: absolute;"/>
        <ui:Button text="Menu" style="position: absolute; top: 200px; font-size: 50px;"/>
    </ui:VisualElement>
</ui:UXML>
